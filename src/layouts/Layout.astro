---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = "Spartan Tyres",
  description = "Quality tyres, fast fitting, honest pricing. Your local tyre specialist in Staines upon Thames, Surrey.",
  path = Astro.url.pathname,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteOrigin = "https://spartanmobiletyres.com";
const canonicalURL = new URL(path, siteOrigin).href;
const ogImage = `${siteOrigin}/img/logo.jpg`;

const nav = [
  { href: base, label: "Home" },
  { href: `${base}services/`, label: "Services" },
  { href: `${base}faq/`, label: "FAQ" },
  { href: `${base}reviews/`, label: "Reviews" },
  { href: `${base}about/`, label: "About" },
  { href: `${base}contact/`, label: "Contact" },
  { href: `${base}game/`, label: "Game" },
];

const normalized = path.endsWith("/") ? path : `${path}/`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "Spartan Tyres",
  "description": "Independent tyre fitting specialist serving Staines upon Thames, Surrey and surrounding areas. New tyres, puncture repairs, wheel balancing and TPMS.",
  "url": siteOrigin,
  "logo": ogImage,
  "image": ogImage,
  "telephone": "+447511928899",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Staines upon Thames",
    "addressRegion": "Surrey",
    "addressCountry": "GB"
  },
  "areaServed": [
    "Staines upon Thames",
    "Surrey",
    "Ashford",
    "Egham",
    "Shepperton",
    "Sunbury on Thames",
    "Weybridge"
  ],
  "openingHours": "Mo-Su 00:00-23:59",
  "priceRange": "££",
  "sameAs": ["https://www.tiktok.com/@beanz377"]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href={`${base}img/logo-icon.jpg`} />
    <link rel="apple-touch-icon" href={`${base}img/logo-icon.jpg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Spartan Tyres" />
    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <div class="global-orb-teal" aria-hidden="true"></div>
    <header class="site-header">
      <div class="inner">
        <a href={base} class="brand" aria-label="Spartan Tyres home"><img src={`${base}img/logo.jpg`} alt="Spartan Tyres" class="brand-logo" width="44" height="44" /></a>
        <nav class="nav">
          {nav.map((item) => (
            <a href={item.href} class={normalized === item.href ? "active" : ""}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-tiktok">
          <a href="https://www.tiktok.com/@beanz377" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.79 1.53V6.75a4.85 4.85 0 0 1-1.02-.06z"/></svg>
            beanz 377
          </a>
          <span>Behind the scenes fits, tyre tips and shop life.</span>
        </div>
        &copy; {new Date().getFullYear()} Spartan Tyres &middot; All rights reserved
      </div>
    </footer>

    <a
      href="https://wa.me/447511928899?text=Hi%2C%20I%27d%20like%20to%20book%20a%20tyre%20fitting"
      class="whatsapp-fab"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat with us on WhatsApp"
    >
      <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      <span>Book via WhatsApp</span>
    </a>

    <script is:inline>
      (function () {
        if (!window.IntersectionObserver) return;
        var targets = document.querySelectorAll('.card, .section-head');
        targets.forEach(function (el) { el.classList.add('will-reveal'); });
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (!e.isIntersecting) return;
            var siblings = Array.from(e.target.parentElement.querySelectorAll('.card.will-reveal'));
            var idx = siblings.indexOf(e.target);
            if (idx > 0) e.target.style.animationDelay = (idx * 0.08) + 's';
            e.target.classList.add('revealed');
            io.unobserve(e.target);
          });
        }, { rootMargin: '0px 0px -40px 0px', threshold: 0.08 });
        targets.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
