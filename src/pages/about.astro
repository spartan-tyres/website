---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About | Spartan Tyres">
  <section class="hero" style="padding: 3.5rem 0 2.5rem;">
    <div class="container">
      <span class="eyebrow">Our story</span>
      <h1>Local, independent, straight talking.</h1>
      <p>Spartan Tyres is a family run fitting centre built on the idea that tyre fitting shouldn't be a hassle or a rip off.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        <div class="card">
          <h3>Experience</h3>
          <p>Over a decade of fitting tyres on everything from city hatchbacks to heavy work vans. We know what works and what doesn't.</p>
        </div>
        <div class="card">
          <h3>Honesty</h3>
          <p>If your tyre can be safely repaired, we'll repair it. We'll never push a sale you don't need.</p>
        </div>
        <div class="card">
          <h3>Speed</h3>
          <p>Most jobs turned around on the same visit. Walk ins welcome; booking guarantees your slot.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
