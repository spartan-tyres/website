---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const services = [
  { title: "New Tyres", desc: "All major brands stocked: budget, mid-range and premium fitted while you wait." },
  { title: "Puncture Repairs", desc: "Safe, industry-standard repairs from £50. Most done in under 30 minutes." },
  { title: "Wheel Balancing", desc: "Eliminate vibration and uneven wear with precision balancing on every fit." },
];

const brands = [
  { name: "Michelin",     size: 32, weight: 900, spacing: "0.05em",  italic: false },
  { name: "Continental",  size: 22, weight: 300, spacing: "0.18em",  italic: false },
  { name: "Pirelli",      size: 30, weight: 900, spacing: "0.02em",  italic: true  },
  { name: "Bridgestone",  size: 20, weight: 700, spacing: "0.04em",  italic: false },
  { name: "Goodyear",     size: 28, weight: 800, spacing: "0.0em",   italic: false },
  { name: "Dunlop",       size: 30, weight: 900, spacing: "0.08em",  italic: false },
  { name: "Yokohama",     size: 20, weight: 600, spacing: "0.14em",  italic: false },
  { name: "Hankook",      size: 26, weight: 800, spacing: "0.06em",  italic: false },
];
---

<Layout title="Spartan Tyres | Quality Tyres, Fast Fitting">
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">Tyres · Repairs · Balancing</span>
        <h1>Quality tyres.<br />Fast fitting.<br />Honest pricing.</h1>
        <p>Spartan Tyres is your local specialist for new tyres, puncture repairs and wheel balancing. Walk-in or book ahead. We'll have you back on the road fast.</p>
        <div class="btn-row">
          <a class="btn" href={`${base}contact/`}>Book a fitting</a>
          <a class="btn secondary" href={`${base}services/`}>See services</a>
        </div>
      </div>
      <div class="hero-logo" aria-hidden="true">
        <img src={`${base}img/logo.jpg`} alt="" width="800" height="800" />
      </div>
    </div>
  </section>

  <a
    href="https://wa.me/447511928899?text=Hi%2C%20I%20have%20a%20flat%20tyre%20and%20need%20help%20right%20now"
    class="emergency-banner"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="emergency-pulse" aria-hidden="true"></span>
    <span class="emergency-text">
      <strong>Flat tyre?</strong> We can help right now.
    </span>
    <span class="emergency-cta">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      Message us on WhatsApp
    </span>
  </a>

  <section class="brands-section">
    <div class="container">
      <p class="brands-label">Brands we stock</p>
      <div class="brands-strip">
        {brands.map((b) => (
          <div class="brand-logo">
            <svg
              height="44"
              viewBox={`0 0 ${b.name.length * b.size * 0.62} 44`}
              xmlns="http://www.w3.org/2000/svg"
              aria-label={b.name}
              role="img"
            >
              <text
                x="50%"
                y="50%"
                dominant-baseline="central"
                text-anchor="middle"
                font-family="system-ui, -apple-system, 'Segoe UI', sans-serif"
                font-size={b.size}
                font-weight={b.weight}
                font-style={b.italic ? "italic" : "normal"}
                letter-spacing={b.spacing}
                fill="currentColor"
              >{b.name}</text>
            </svg>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <h2>What we do</h2>
        <p>Everything your vehicle needs to stay safe and roadworthy.</p>
      </div>
      <div class="grid">
        {services.map((s) => (
          <div class="card">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <h2>Why Spartan?</h2>
      </div>
      <div class="grid">
        <div class="card"><h3>No-nonsense pricing</h3><p>Fixed, transparent prices. No surprise add-ons at the till.</p></div>
        <div class="card"><h3>Same-day fitting</h3><p>Walk-in welcome. Most fits take 20 to 40 minutes.</p></div>
        <div class="card"><h3>Trusted brands</h3><p>Michelin, Continental, Pirelli, Bridgestone and more in stock.</p></div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    gap: 2rem;
    align-items: center;
  }
  .hero-logo {
    max-width: 420px;
    justify-self: end;
    width: 100%;
  }
  .hero-logo img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    box-shadow: 0 0 60px rgba(255, 107, 26, 0.25);
  }
  @media (max-width: 760px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-logo { max-width: 260px; justify-self: center; order: -1; margin-bottom: 0.5rem; }
  }

  /* Emergency banner */
  .emergency-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1rem 1.25rem;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    transition: background 0.15s;
  }
  .emergency-banner:hover { background: #1ebe5d; }

  .emergency-pulse {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.5); }
  }

  .emergency-text { font-size: 1rem; color: #fff; }
  .emergency-text strong { color: #fff; font-weight: 800; }

  .emergency-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.4rem 0.9rem;
    border: 2px solid rgba(255,255,255,0.7);
    border-radius: 50px;
    color: #fff;
    white-space: nowrap;
  }

  /* Brands strip */
  .brands-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-alt);
  }
  .brands-label {
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin: 0 0 1.75rem;
  }
  .brands-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .brand-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--muted);
    transition: color 0.2s, border-color 0.2s, box-shadow 0.2s;
    cursor: default;
  }
  .brand-logo:hover {
    color: var(--text);
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(179, 36, 36, 0.15);
  }
  .brand-logo svg { display: block; }
</style>
