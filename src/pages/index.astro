---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const services = [
  {
    num: "01",
    title: "New Tyres",
    desc: "All major brands stocked: budget, mid range and premium fitted while you wait.",
    price: "From £80",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/></svg>`,
  },
  {
    num: "02",
    title: "Puncture Repairs",
    desc: "Safe, industry standard repairs. Most done in under 30 minutes.",
    price: "From £50",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    num: "03",
    title: "Wheel Balancing",
    desc: "Eliminate vibration and uneven wear with precision balancing on every fit.",
    price: "From £8 per wheel",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  },
];

const brands = [
  { name: "Michelin",    domain: "michelin.com" },
  { name: "Bridgestone", domain: "bridgestone.com" },
  { name: "Continental", domain: "continental-tires.com" },
  { name: "Goodyear",    domain: "goodyear.com" },
  { name: "Pirelli",     domain: "pirelli.com" },
];
---

<Layout title="Spartan Tyres | Quality Tyres, Fast Fitting">
  <section class="hero">
    <div class="hero-bg-orb" aria-hidden="true"></div>
    <div class="hero-stripes" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">Tyres · Repairs · Balancing</span>
        <h1>Quality tyres.<br />Fast fitting.<br />Honest pricing.</h1>
        <p>Spartan Tyres is your local specialist for new tyres, puncture repairs and wheel balancing. Walk in or book ahead. We'll have you back on the road fast.</p>
        <div class="btn-row">
          <a class="btn" href={`${base}contact/`}>Book a fitting</a>
          <a class="btn secondary" href={`${base}services/`}>See services</a>
        </div>
      </div>
      <div class="hero-logo" aria-hidden="true">
        <img src={`${base}img/logo.jpg`} alt="" width="800" height="800" />
      </div>
    </div>
  </section>

  <a
    href="https://wa.me/447511928899?text=Hi%2C%20I%20have%20a%20flat%20tyre%20and%20need%20help%20right%20now"
    class="emergency-banner"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="emergency-pulse" aria-hidden="true"></span>
    <span class="emergency-text">
      <strong>Flat tyre?</strong> We can help right now.
    </span>
    <span class="emergency-cta">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      Message us on WhatsApp
    </span>
  </a>

  <section class="brands-section colour-teal">
    <div class="container">
      <p class="brands-label">Brands we stock</p>
      <div class="brands-strip">
        {brands.map((b) => (
          <div class="brand-tile">
            <img
              src={`https://logo.clearbit.com/${b.domain}`}
              alt={b.name}
              width="140"
              height="56"
              loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
            />
            <span class="brand-fallback">{b.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="colour-orange">
    <div class="container">
      <div class="section-head">
        <h2>What we do</h2>
        <p>Everything your vehicle needs to stay safe and roadworthy.</p>
      </div>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service-card">
            <div class="service-top">
              <span class="service-num">{s.num}</span>
              <span class="service-icon" set:html={s.icon} />
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <span class="service-price">{s.price}</span>
          </div>
        ))}
      </div>
      <div class="services-footer">
        <a href={`${base}services/`} class="btn secondary">See all services &amp; pricing</a>
      </div>
    </div>
  </section>

  <section class="colour-purple">
    <div class="container">
      <div class="section-head">
        <h2>Why Spartan?</h2>
      </div>
      <div class="grid">
        <div class="card"><h3>No nonsense pricing</h3><p>Fixed, transparent prices. No surprise add ons at the till.</p></div>
        <div class="card"><h3>We come to you</h3><p>Mobile fitting at your home or workplace. Most jobs done in 20 to 40 minutes.</p></div>
        <div class="card"><h3>Trusted brands</h3><p>Michelin, Continental, Pirelli, Bridgestone and more in stock.</p></div>
      </div>
    </div>
  </section>

  <section class="game-section">
    <div class="container game-layout">

      <div class="game-copy">
        <span class="eyebrow">Exclusive offer</span>
        <h2>Beat the game.<br />Save on your fitting.</h2>
        <p>Score <strong>200+</strong> in Tyre Dodger and unlock 10% off your next fitting. The code appears the moment you hit the target.</p>

        <div class="target-badge">
          <span class="target-label">Target score</span>
          <span class="target-value">200</span>
        </div>

        <div id="promo-box" class="promo-box" aria-live="polite" aria-atomic="true">
          <p class="promo-unlock">You did it!</p>
          <p class="promo-label">Your 10% discount code</p>
          <div class="promo-row">
            <span class="promo-code">DODGE10</span>
            <button id="promo-copy" class="promo-copy-btn" type="button">Copy</button>
          </div>
          <p class="promo-note">Mention this code when you book. Valid on any service.</p>
        </div>
      </div>

      <div class="game-canvas-wrap">
        <canvas id="hgc"></canvas>
        <p class="game-hint-sm">Arrow keys or touch to move &middot; Space to start</p>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    background: #0e0e12;
  }
  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .hero::before {
    width: 700px; height: 700px;
    top: -200px; right: -100px;
    background: radial-gradient(circle, rgba(220,50,30,.75) 0%, rgba(255,120,20,.45) 45%, transparent 70%);
    animation: orb-a 8s ease-in-out infinite alternate;
  }
  .hero::after {
    width: 500px; height: 500px;
    top: -100px; left: -80px;
    background: radial-gradient(circle, rgba(120,40,200,.55) 0%, rgba(60,20,140,.3) 50%, transparent 70%);
    animation: orb-b 10s ease-in-out infinite alternate;
  }
  .hero-bg-orb {
    position: absolute;
    bottom: -120px; left: 10%;
    width: 460px; height: 460px;
    border-radius: 50%;
    filter: blur(70px);
    background: radial-gradient(circle, rgba(255,180,0,.4) 0%, rgba(200,100,20,.25) 50%, transparent 70%);
    pointer-events: none; z-index: 0;
    animation: orb-c 12s ease-in-out infinite alternate;
  }
  .hero-stripes {
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(45deg, transparent 0px, transparent 26px, rgba(255,255,255,.025) 26px, rgba(255,255,255,.025) 28px);
    background-size: 56px 56px;
    animation: stripes 6s linear infinite;
    pointer-events: none; z-index: 0;
  }
  @keyframes orb-a {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(-60px,40px) scale(1.12); }
  }
  @keyframes orb-b {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(50px,60px) scale(1.08); }
  }
  @keyframes orb-c {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(40px,-50px) scale(1.15); }
  }
  @keyframes stripes {
    from { background-position: 0 0; }
    to   { background-position: 56px 56px; }
  }
  .hero .container { position: relative; z-index: 1; }

  /* ── Section colour washes ── */
  .colour-teal {
    position: relative;
    overflow: hidden;
  }
  .colour-teal::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 100% at 0% 50%, rgba(0,180,160,.18) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 100% 50%, rgba(0,120,220,.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .colour-orange {
    position: relative;
    overflow: hidden;
  }
  .colour-orange::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 120% at 100% 0%, rgba(255,120,20,.16) 0%, transparent 65%),
      radial-gradient(ellipse 50% 80% at 0% 100%, rgba(220,50,30,.12) 0%, transparent 65%);
    pointer-events: none;
  }

  .colour-purple {
    position: relative;
    overflow: hidden;
  }
  .colour-purple::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 120% at 50% 0%, rgba(120,40,200,.16) 0%, transparent 65%),
      radial-gradient(ellipse 50% 60% at 100% 100%, rgba(255,180,0,.1) 0%, transparent 65%);
    pointer-events: none;
  }

  /* Ensure content sits above the washes */
  .colour-teal .container,
  .colour-orange .container,
  .colour-purple .container { position: relative; z-index: 1; }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    gap: 2rem;
    align-items: center;
  }
  .hero-logo {
    max-width: 420px;
    justify-self: end;
    width: 100%;
  }
  .hero-logo img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    box-shadow: 0 0 80px rgba(220, 80, 20, 0.5), 0 0 160px rgba(120, 40, 200, 0.2);
  }
  @media (max-width: 760px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-logo { max-width: 260px; justify-self: center; order: -1; margin-bottom: 0.5rem; }
  }

  /* Emergency banner */
  .emergency-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1rem 1.25rem;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    transition: background 0.15s;
  }
  .emergency-banner:hover { background: #1ebe5d; }
  .emergency-pulse {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
    animation: pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.5); }
  }
  .emergency-text { font-size: 1rem; color: #fff; }
  .emergency-text strong { color: #fff; font-weight: 800; }
  .emergency-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.4rem 0.9rem;
    border: 2px solid rgba(255,255,255,0.7);
    border-radius: 50px;
    color: #fff;
    white-space: nowrap;
  }

  /* Brand logos */
  .brands-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-alt);
  }
  .brands-label {
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin: 0 0 1.75rem;
  }
  .brands-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .brand-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    min-width: 140px;
  }
  .brand-tile img {
    display: block;
    width: auto;
    height: 48px;
    object-fit: contain;
    filter: grayscale(1) brightness(1.9);
    transition: filter 0.25s;
  }
  .brand-tile:hover img { filter: grayscale(0) brightness(1); }
  .brand-fallback {
    display: none;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Services */
  .services-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .service-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(179, 36, 36, 0.18);
    border-color: var(--accent);
  }
  .service-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .service-num {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--accent);
    opacity: 0.7;
  }
  .service-icon {
    width: 28px;
    height: 28px;
    color: var(--accent);
    opacity: 0.85;
  }
  .service-icon svg { width: 100%; height: 100%; }
  .service-card h3 { font-size: 1.1rem; margin: 0; }
  .service-card p { margin: 0; font-size: 0.93rem; flex: 1; }
  .service-price {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
  }
  .services-footer { margin-top: 1.75rem; }

  /* ── Game section ── */
  .game-section {
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .game-section::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 100% at 0% 50%, rgba(179,36,36,.1) 0%, transparent 65%);
    pointer-events: none;
  }
  .game-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .game-copy { display: flex; flex-direction: column; gap: 1rem; }
  .game-copy h2 { margin-bottom: 0; }
  .game-copy > p strong { color: var(--text); }

  .target-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.6rem 1rem;
    width: fit-content;
  }
  .target-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }
  .target-value {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
  }

  /* Promo box — hidden until unlocked */
  .promo-box {
    background: var(--surface);
    border: 2px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .promo-box.revealed {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .promo-unlock {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }
  .promo-label { font-size: 0.8rem; color: var(--muted); margin: 0; }
  .promo-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0.25rem 0;
  }
  .promo-code {
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    color: var(--text);
    line-height: 1;
  }
  .promo-copy-btn {
    padding: 0.4rem 0.9rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
    font-family: inherit;
  }
  .promo-copy-btn:hover { background: var(--accent-hover); }
  .promo-note { font-size: 0.78rem; color: var(--muted); margin: 0; }

  /* Canvas wrap */
  .game-canvas-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
  #hgc {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 7;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    cursor: crosshair;
    touch-action: none;
  }
  .game-hint-sm {
    font-size: 0.75rem;
    color: var(--muted);
    text-align: center;
    margin: 0;
  }

  @media (max-width: 860px) {
    .game-layout {
      grid-template-columns: 1fr;
    }
    .game-canvas-wrap { order: -1; }
  }
</style>

<script is:inline>
(function () {
  const canvas = document.getElementById('hgc');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  const WIN_DISPLAY = 200; // score shown to player
  const WIN_TICKS   = WIN_DISPLAY * 10;

  function sync() {
    const r = canvas.getBoundingClientRect();
    canvas.width  = Math.round(r.width);
    canvas.height = Math.round(r.height);
  }
  sync();
  window.addEventListener('resize', sync);

  const P = {
    bg:'#151518', road:'#1c1c21', edge:'#2f2f35', dash:'#38383f',
    accent:'#b32424', text:'#efe6da', muted:'#8e857a',
    rubber:'#252528', rim:'#999', silver:'#c8c8c8',
  };

  let phase = 'start', score = 0, best = 0, lives = 3;
  let spd = 0, gTick = 0, aTick = 0, dashX = 0, inv = 0;
  let won = false;

  function road() {
    const top = Math.round(canvas.height * 0.08);
    const bot = Math.round(canvas.height * 0.92);
    return { top, bot, h: bot - top };
  }

  const pl = {
    x:0, y:0, r:0, vy:0, angle:0,
    reset() {
      this.r = Math.round(canvas.height * 0.1);
      this.x = Math.round(canvas.width  * 0.14);
      this.y = Math.round(canvas.height * 0.5);
      this.vy = 0; this.angle = 0;
    },
    update() {
      this.y += this.vy;
      const rd = road();
      this.y = Math.max(rd.top + this.r, Math.min(rd.bot - this.r, this.y));
      this.angle += spd * 0.042;
    },
    draw() {
      if (inv > 0 && Math.floor(inv / 5) % 2 === 1) return;
      ctx.save(); ctx.translate(this.x, this.y);
      ctx.beginPath(); ctx.arc(0,0,this.r,0,Math.PI*2);
      ctx.fillStyle = P.rubber; ctx.fill();
      ctx.beginPath(); ctx.arc(0,0,this.r,0,Math.PI*2);
      ctx.strokeStyle = '#3a3a3d'; ctx.lineWidth = this.r*0.18; ctx.stroke();
      ctx.save(); ctx.rotate(this.angle);
      const ri = this.r*0.58;
      ctx.beginPath(); ctx.arc(0,0,ri,0,Math.PI*2);
      ctx.fillStyle = P.rim; ctx.fill();
      ctx.strokeStyle='#bbb'; ctx.lineWidth=this.r*0.08;
      for(let i=0;i<5;i++){
        const a=(Math.PI*2/5)*i;
        ctx.beginPath();
        ctx.moveTo(Math.cos(a)*this.r*0.18,Math.sin(a)*this.r*0.18);
        ctx.lineTo(Math.cos(a)*ri*0.95,   Math.sin(a)*ri*0.95);
        ctx.stroke();
      }
      ctx.beginPath(); ctx.arc(0,0,this.r*0.18,0,Math.PI*2);
      ctx.fillStyle=P.accent; ctx.fill();
      ctx.restore(); ctx.restore();
    }
  };

  let obs=[], spawnCD=0;

  function spawn() {
    const rd=road(), lanes=3, lane=Math.floor(Math.random()*lanes);
    const y = rd.top+(rd.h/lanes)*(lane+0.5);
    const type = Math.random()<0.42?'nail':'hole';
    obs.push({ type, x:canvas.width+60, y,
      w:type==='hole'?canvas.height*0.15:canvas.height*0.026,
      h:type==='hole'?canvas.height*0.09 :canvas.height*0.075 });
  }

  function drawNail(o) {
    ctx.save(); ctx.translate(o.x,o.y); ctx.rotate(0.35);
    const hw=o.w*0.5, hh=o.h*0.5;
    ctx.fillStyle=P.silver;
    ctx.fillRect(-hw,-hh*0.6,hw*2,hh*1.1);
    ctx.beginPath(); ctx.moveTo(-hw*1.2,hh*0.5); ctx.lineTo(0,hh*1.6); ctx.lineTo(hw*1.2,hh*0.5);
    ctx.fillStyle='#aaa'; ctx.fill();
    ctx.beginPath(); ctx.ellipse(0,-hh*0.7,hw*2.2,hh*0.45,0,0,Math.PI*2);
    ctx.fillStyle='#b0b0b0'; ctx.fill();
    ctx.restore();
  }

  function drawHole(o) {
    ctx.save(); ctx.translate(o.x,o.y);
    const rx=o.w*0.5, ry=o.h*0.5;
    ctx.beginPath(); ctx.ellipse(rx*0.18,ry*0.22,rx,ry,0,0,Math.PI*2);
    ctx.fillStyle='rgba(0,0,0,0.4)'; ctx.fill();
    ctx.beginPath(); ctx.ellipse(0,0,rx,ry,0,0,Math.PI*2);
    ctx.fillStyle='#07070a'; ctx.fill();
    ctx.beginPath(); ctx.ellipse(-rx*0.12,-ry*0.12,rx*0.65,ry*0.62,0,0,Math.PI*2);
    ctx.fillStyle='#030305'; ctx.fill();
    ctx.beginPath(); ctx.ellipse(0,0,rx,ry,0,0,Math.PI*2);
    ctx.strokeStyle='#1e1e24'; ctx.lineWidth=3; ctx.stroke();
    ctx.restore();
  }

  function hit(o) {
    const pr=pl.r*0.70;
    const ox=o.type==='nail'?o.w*0.4:o.w*0.42;
    const oy=o.type==='nail'?o.h*0.55:o.h*0.42;
    return Math.abs(pl.x-o.x)<pr+ox && Math.abs(pl.y-o.y)<pr+oy;
  }

  const keys={};
  window.addEventListener('keydown',e=>{
    keys[e.key]=true;
    if([' ','ArrowUp','ArrowDown','w','s'].includes(e.key)) e.preventDefault();
    if((e.key===' '||e.key==='Enter')&&phase!=='playing') begin();
  });
  window.addEventListener('keyup',e=>{ delete keys[e.key]; });

  let touchY=null;
  canvas.addEventListener('touchstart',e=>{ e.preventDefault(); touchY=e.touches[0].clientY; if(phase!=='playing') begin(); },{passive:false});
  canvas.addEventListener('touchmove',e=>{ e.preventDefault(); if(phase!=='playing'||touchY===null) return; pl.vy=(e.touches[0].clientY-touchY)*0.3; touchY=e.touches[0].clientY; },{passive:false});
  canvas.addEventListener('touchend',e=>{ e.preventDefault(); pl.vy*=0.2; touchY=null; },{passive:false});
  canvas.addEventListener('click',()=>{ if(phase!=='playing') begin(); });

  function revealPromo() {
    if(won) return;
    won=true;
    const box=document.getElementById('promo-box');
    if(box) box.classList.add('revealed');
    box.scrollIntoView({ behavior:'smooth', block:'nearest' });
  }

  document.getElementById('promo-copy')?.addEventListener('click',function(){
    navigator.clipboard.writeText('DODGE10').then(()=>{
      this.textContent='Copied!';
      setTimeout(()=>{ this.textContent='Copy'; },2000);
    }).catch(()=>{
      this.textContent='DODGE10';
    });
  });

  function begin() {
    phase='playing'; score=0; lives=3; spd=4; gTick=0; inv=0;
    obs=[]; spawnCD=70; won=false; pl.reset();
  }

  function update() {
    if(phase!=='playing') return;
    gTick++; score++;
    spd=4+Math.min(gTick/350,5);
    dashX=(dashX+spd)%44;
    spawnCD--;
    if(spawnCD<=0){ spawn(); spawnCD=Math.max(36,70-Math.floor(gTick/180)*4); }
    for(const o of obs) o.x-=spd;
    obs=obs.filter(o=>o.x>-120);
    const PSPD=Math.round(canvas.height*0.014);
    if(keys['ArrowUp']||keys['w'])      pl.vy=-PSPD;
    else if(keys['ArrowDown']||keys['s']) pl.vy=PSPD;
    else if(touchY===null)               pl.vy*=0.72;
    pl.update();
    if(score>=WIN_TICKS && !won) revealPromo();
    if(inv>0){ inv--; } else {
      for(const o of obs){ if(hit(o)){ lives--; inv=90; o.x=-300; if(lives<=0){ phase='dead'; best=Math.max(best,score); } break; } }
    }
  }

  function drawRoad() {
    const rd=road();
    ctx.fillStyle=P.road; ctx.fillRect(0,rd.top,canvas.width,rd.h);
    ctx.fillStyle=P.edge; ctx.fillRect(0,rd.top,canvas.width,4); ctx.fillRect(0,rd.bot-4,canvas.width,4);
    ctx.save(); ctx.setLineDash([28,16]); ctx.lineDashOffset=-dashX;
    ctx.beginPath(); ctx.moveTo(0,rd.top+rd.h/2); ctx.lineTo(canvas.width,rd.top+rd.h/2);
    ctx.strokeStyle=P.dash; ctx.lineWidth=3; ctx.stroke(); ctx.restore();
  }

  function drawHUD() {
    ctx.fillStyle=P.text; ctx.font=`700 ${Math.round(canvas.height*0.055)}px system-ui`;
    ctx.textAlign='left';
    const d=Math.floor(score/10);
    ctx.fillText('Score: '+d, 14, Math.round(canvas.height*0.07));
    if(score<WIN_TICKS){
      ctx.fillStyle=P.muted; ctx.font=`${Math.round(canvas.height*0.042)}px system-ui`;
      ctx.fillText('Target: '+WIN_DISPLAY, 14, Math.round(canvas.height*0.13));
    }
    const lr=Math.round(canvas.height*0.04);
    for(let i=0;i<3;i++){
      const lx=canvas.width-14-lr-i*(lr*2+8), ly=Math.round(canvas.height*0.065);
      ctx.globalAlpha=i<lives?1:0.18;
      ctx.beginPath(); ctx.arc(lx,ly,lr,0,Math.PI*2); ctx.fillStyle=P.rubber; ctx.fill();
      ctx.beginPath(); ctx.arc(lx,ly,lr*0.52,0,Math.PI*2); ctx.fillStyle=P.accent; ctx.fill();
      ctx.globalAlpha=1;
    }
  }

  function pill(x,y,w,h,r){
    ctx.beginPath(); ctx.moveTo(x+r,y);
    ctx.arcTo(x+w,y,x+w,y+h,r); ctx.arcTo(x+w,y+h,x,y+h,r);
    ctx.arcTo(x,y+h,x,y,r);     ctx.arcTo(x,y,x+w,y,r);
    ctx.closePath();
  }

  function overlay(title,l1,l2,btn) {
    ctx.fillStyle='rgba(21,21,24,0.88)'; ctx.fillRect(0,0,canvas.width,canvas.height);
    const cx=canvas.width/2, cy=canvas.height/2, fs=canvas.height*0.065;
    ctx.textAlign='center';
    ctx.fillStyle=P.accent; ctx.font=`900 ${Math.round(fs*1.1)}px system-ui`; ctx.fillText(title,cx,cy-fs*1.6);
    ctx.fillStyle=P.text;   ctx.font=`${Math.round(fs*0.6)}px system-ui`;    ctx.fillText(l1,cx,cy-fs*0.55);
    if(l2){ ctx.fillStyle=P.muted; ctx.font=`${Math.round(fs*0.52)}px system-ui`; ctx.fillText(l2,cx,cy-fs*0.08); }
    const bw=Math.round(canvas.width*0.45), bh=Math.round(canvas.height*0.14);
    const bx=cx-bw/2, by=cy+fs*0.45;
    ctx.globalAlpha=0.78+Math.sin(aTick*0.055)*0.22;
    ctx.fillStyle=P.accent; pill(bx,by,bw,bh,6); ctx.fill(); ctx.globalAlpha=1;
    ctx.fillStyle='#fff'; ctx.font=`700 ${Math.round(fs*0.5)}px system-ui`; ctx.fillText(btn,cx,by+bh*0.64);
    ctx.textAlign='left';
  }

  function loop() {
    aTick++; update();
    ctx.fillStyle=P.bg; ctx.fillRect(0,0,canvas.width,canvas.height);
    drawRoad();
    for(const o of obs) o.type==='nail'?drawNail(o):drawHole(o);
    pl.draw();
    if(phase==='playing') drawHUD();
    if(phase==='start')   overlay('TYRE DODGER','Dodge nails and potholes!','Score 200+ to unlock 10% off','TAP / PRESS SPACE TO START');
    if(phase==='dead')    overlay('PUNCTURED!','Score: '+Math.floor(score/10),'Best: '+Math.floor(best/10),'PLAY AGAIN');
    requestAnimationFrame(loop);
  }

  pl.reset(); loop();
})();
</script>
