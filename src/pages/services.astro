---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;

const services = [
  { title: "New Tyre Supply & Fitting", desc: "Budget, mid-range and premium tyres for cars, vans and 4x4s, fitted, balanced and ready to drive.", price: "Starting from £80" },
  { title: "Puncture Repairs", desc: "British Standard BS AU 159 repairs. Safe for the life of the tyre when the damage is in the repairable zone.", price: "Starting from £50" },
  { title: "Wheel Balancing", desc: "Computer balancing included with every new tyre or available as a standalone service.", price: "From £8 per wheel" },
  { title: "TPMS Service", desc: "Tyre pressure monitoring sensor replacement and re-programming.", price: "£70" },
  { title: "Seasonal Tyre Changeovers", desc: "Winter/summer swaps with safe storage available on request.", price: "£80" },
];
---

<Layout title="Services | Spartan Tyres">
  <section class="hero" style="padding: 3.5rem 0 2.5rem;">
    <div class="container">
      <span class="eyebrow">What we offer</span>
      <h1>Services &amp; Pricing</h1>
      <p>Straightforward pricing, pro workmanship. No hidden fees, ever.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid">
        {services.map((s) => (
          <div class="card service-card">
            <div class="service-card-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
            <div class="service-card-footer">
              <span class="service-price">{s.price}</span>
              <a href={`${base}contact/`} class="btn service-btn">Book this</a>
            </div>
          </div>
        ))}
      </div>
      <p style="margin-top: 2rem; font-size: 0.9rem;">Prices are indicative and may vary by vehicle and tyre. For an exact quote, drop us a message on the <a href={`${base}contact/`} style="color: var(--accent);">contact page</a>.</p>
    </div>
  </section>
</Layout>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }
  .service-card-body { flex: 1; }
  .service-card-body p { margin: 0; }
  .service-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .service-price {
    color: var(--accent);
    font-weight: 700;
    font-size: 1rem;
  }
  .service-btn {
    padding: 0.55rem 1.1rem;
    font-size: 0.9rem;
  }
</style>
